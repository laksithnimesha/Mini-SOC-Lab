<group name="local,syslog,sshd,">



  <rule id="100100" level="12" frequency="5" timeframe="60">

    <if_matched_sid>5710</if_matched_sid>

    <same_source_ip />

    <description>Possible SSH Brute Force Detected</description>

    <group>authentication_failures,bruteforce,ssh,</group>

    <mitre>

      <id>T1110</id>

    </mitre>

  </rule>



</group>
